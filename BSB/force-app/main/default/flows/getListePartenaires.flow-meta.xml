        <locationX>176</locationX>
        <locationY>734</locationY>
        <assignmentItems>
            <assignToReference>txtNomsPartenaires</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fRemoveExtraChar</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>Should_skip_record</name>
        <label>Should skip record ?</label>
        <locationX>352</locationX>
        <locationY>350</locationY>
        <defaultConnector>
            <targetReference>assignPartenaire</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Do not skip</defaultConnectorLabel>
        <rules>
            <name>skip</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>skipRecordId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>loop_Partenaires.Id</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>loop_Partenaires</targetReference>
            </connector>
            <label>Skip</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <description>Formula to remove extra char from string nom Partenaires</description>
        <name>fRemoveExtraChar</name>
        <dataType>String</dataType>
        <expression>LEFT({!txtNomsPartenaires}, LEN({!txtNomsPartenaires}) - 3)</expression>
    </formulas>
    <interviewLabel>getListePartenaires {!$Flow.CurrentDateTime}</interviewLabel>
    <label>getListePartenaires</label>
    <loops>
