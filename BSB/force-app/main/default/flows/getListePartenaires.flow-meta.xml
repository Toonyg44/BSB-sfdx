    <assignments>
        <description>add current Partenaire name + a separator char (/)</description>
        <name>assignPartenaire</name>
        <label>assignPartenaire</label>
        <locationX>440</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>txtNomsPartenaires</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>loop_Partenaires.Compte__r.Name</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txtNomsPartenaires</assignToReference>
            <operator>Add</operator>
