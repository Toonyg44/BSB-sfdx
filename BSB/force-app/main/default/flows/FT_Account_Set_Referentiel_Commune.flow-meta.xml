    <assignments>
        <name>Assign_Agglomeration</name>
        <label>Assign Agglomeration</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Referentiel_Commune__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>vRefCommune.Id</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>assign_record</name>
        <label>assign record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>vRefCommune</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Into_Referentiel_Commune</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Into_Referentiel_Commune</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Copy_1_of_assign_record</name>
        <label>assign record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>vRefCommune</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Into_Referentiel_Commune</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Into_Referentiel_Commune</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>getNumber_of_Items</name>
        <label>getNumber of Items</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>varNumberOfItems</assignToReference>
            <operator>AssignCount</operator>
            <value>
                <elementReference>Get_Referentiel</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Into_Referentiel_Commune</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Agglomeration_Found</name>
        <label>Agglomeration Found ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Not Found</defaultConnectorLabel>
        <rules>
            <name>Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>vRefCommune</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Agglomeration</targetReference>
            </connector>
            <label>Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Should_Assign</name>
        <label>Should Assign ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Into_Referentiel_Commune</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No match</defaultConnectorLabel>
        <rules>
            <name>One_Record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varNumberOfItems</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>assign_record</targetReference>
            </connector>
            <label>One Record</label>
        </rules>
        <rules>
            <name>More_than_One_and_city_match</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varNumberOfItems</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Into_Referentiel_Commune.Commune__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>fCity</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_1_of_assign_record</targetReference>
            </connector>
            <label>More than One and city match</label>
        </rules>
    </decisions>
