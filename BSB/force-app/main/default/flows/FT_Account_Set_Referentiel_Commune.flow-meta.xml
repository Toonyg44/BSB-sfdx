        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>getNumber_of_Items</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Code_Postal__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.ShippingPostalCode</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Agglomeration__c</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>Commune__c</queriedFields>
        <queriedFields>Agglomeration__c</queriedFields>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Referentiel</targetReference>
        </connector>
        <filterFormula>OR(
ISNEW(), 
ISCHANGED({!$Record.ShippingPostalCode}),
ISCHANGED({!$Record.ShippingCity})
)</filterFormula>
        <object>Account</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
